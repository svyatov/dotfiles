{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Edit",
      "Write",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(bun:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(ruby:*)",
      "Bash(gem:*)",
      "Bash(rails:*)",
      "Bash(rake:*)",
      "Bash(bundle:*)",
      "Bash(go:*)",
      "Bash(make:*)",
      "Bash(just:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(docker:*)",
      "Bash(golangci-lint:*)",
      "Bash(task:*)",
      "Skill(leo:commit)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.secrets)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(rm:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "filepath=$(jq -r '.tool_input.file_path // empty'); if [ -n \"$filepath\" ] && echo \"$filepath\" | grep -qE '\\.md$'; then markdownlint-cli2 \"$filepath\" 2>&1 | tail -20; fi",
            "timeout": 15,
            "statusMessage": "Markdown lint..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "SessionStart": []
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "impeccable@impeccable": true,
    "caveman@caveman": true,
    "sentry@claude-plugins-official": false,
    "remember@claude-plugins-official": false,
    "ai-firstify@claude-plugins-official": false,
    "compound-engineering@compound-engineering-plugin": true,
    "ralph-loop@claude-plugins-official": true,
    "context-mode@context-mode": true,
    "commit@leo-toolkit": true,
    "import-skill@leo-toolkit": true,
    "grill-me@leo-toolkit": true
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      },
      "autoUpdate": true
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      },
      "autoUpdate": true
    },
    "compound-engineering-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      },
      "autoUpdate": true
    },
    "leo-toolkit": {
      "source": {
        "source": "github",
        "repo": "svyatov/agent-toolkit"
      },
      "autoUpdate": true
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      },
      "autoUpdate": true
    }
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "xhigh",
  "prefersReducedMotion": true,
  "preferredNotifChannel": "ghostty",
  "agentPushNotifEnabled": false,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
