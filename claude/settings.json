{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Edit",
      "Write",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(bun:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(ruby:*)",
      "Bash(gem:*)",
      "Bash(rails:*)",
      "Bash(rake:*)",
      "Bash(bundle:*)",
      "Bash(go:*)",
      "Bash(make:*)",
      "Bash(just:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(docker:*)",
      "Bash(go build:*)",
      "Bash(golangci-lint linters:*)",
      "Bash(golangci-lint run:*)",
      "Bash(task lint:*)",
      "Bash(task test:*)",
      "Bash(oz:*)",
      "Bash(./oz:*)",
      "Bash(for dir:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.secrets)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(rm:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "filepath=$(jq -r '.tool_input.file_path // empty'); if [ -n \"$filepath\" ] && echo \"$filepath\" | grep -qE '\\.md$'; then markdownlint-cli2 \"$filepath\" 2>&1 | tail -20; fi",
            "timeout": 15,
            "statusMessage": "Markdown lint..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "high",
  "voiceEnabled": true,
  "prefersReducedMotion": true
}
